# ──────────────────────────────────────────────────────────────────────────────
# CustomerSupport-Production — environment variables
# Copy to frontend/.env and fill in real values.
# NEVER commit the real .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# Generate a strong random key:  openssl rand -hex 32
SECRET_KEY=change-me-use-openssl-rand-hex-32

# Set to true only in local development
DEBUG=false

# Set to true when running behind HTTPS (load balancer, CloudFront, etc.)
HTTPS_ONLY=false

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_PROFILE=anish0637
AWS_DEFAULT_REGION=us-east-1

# ── Cognito ───────────────────────────────────────────────────────────────────
COGNITO_CLIENT_ID=4hqbuvfji23kgdeqqn2cujs5p4
COGNITO_DOMAIN=https://customersupport-workshop.auth.us-east-1.amazoncognito.com

# ── App ───────────────────────────────────────────────────────────────────────
# Where Cognito will redirect after login — must match the app client setting
REDIRECT_URI=http://localhost:8501/callback
HOST=0.0.0.0
PORT=8501
